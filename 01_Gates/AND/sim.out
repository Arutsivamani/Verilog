#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x55ccf9dae570 .scope module, "and_gate_tb" "and_gate_tb" 2 1;
 .timescale 0 0;
v0x55ccf9dc1200_0 .var "A", 0 0;
v0x55ccf9dc12d0_0 .var "B", 0 0;
v0x55ccf9dc13a0_0 .net "Y", 0 0, v0x55ccf9dc10e0_0;  1 drivers
S_0x55ccf9dae700 .scope module, "dut" "and_gate" 2 7, 3 1 0, S_0x55ccf9dae570;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "y";
v0x55ccf9dae950_0 .net "a", 0 0, v0x55ccf9dc1200_0;  1 drivers
v0x55ccf9dc1020_0 .net "b", 0 0, v0x55ccf9dc12d0_0;  1 drivers
v0x55ccf9dc10e0_0 .var "y", 0 0;
E_0x55ccf9d75dc0 .event anyedge, v0x55ccf9dae950_0, v0x55ccf9dc1020_0;
    .scope S_0x55ccf9dae700;
T_0 ;
    %wait E_0x55ccf9d75dc0;
    %load/vec4 v0x55ccf9dae950_0;
    %load/vec4 v0x55ccf9dc1020_0;
    %and;
    %store/vec4 v0x55ccf9dc10e0_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55ccf9dae570;
T_1 ;
    %vpi_call 2 9 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call 2 10 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x55ccf9dae570 {0 0 0};
    %vpi_call 2 11 "$monitor", "Time = %0t a = %b b = %b y= %b", $time, v0x55ccf9dc1200_0, v0x55ccf9dc12d0_0, v0x55ccf9dc13a0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ccf9dc1200_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ccf9dc12d0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ccf9dc1200_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55ccf9dc12d0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55ccf9dc1200_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ccf9dc12d0_0, 0, 1;
    %delay 10, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55ccf9dc1200_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x55ccf9dc12d0_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 17 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "and_gate_tb.v";
    "and_gate.v";
