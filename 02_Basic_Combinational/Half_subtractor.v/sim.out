#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x644ab268fa50 .scope module, "half_subtractor_tb" "half_subtractor_tb" 2 1;
 .timescale 0 0;
v0x644ab26a2e00_0 .var "a", 0 0;
v0x644ab26a2ec0_0 .var "b", 0 0;
v0x644ab26a2f90_0 .net "bout", 0 0, v0x644ab26a2bc0_0;  1 drivers
v0x644ab26a3090_0 .net "d", 0 0, v0x644ab26a2c90_0;  1 drivers
S_0x644ab268fbe0 .scope module, "uut" "half_subtractor" 2 4, 3 1 0, S_0x644ab268fa50;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "d";
    .port_info 3 /OUTPUT 1 "bout";
v0x644ab2656490_0 .net "a", 0 0, v0x644ab26a2e00_0;  1 drivers
v0x644ab26a2b00_0 .net "b", 0 0, v0x644ab26a2ec0_0;  1 drivers
v0x644ab26a2bc0_0 .var "bout", 0 0;
v0x644ab26a2c90_0 .var "d", 0 0;
E_0x644ab26576a0 .event anyedge, v0x644ab2656490_0, v0x644ab26a2b00_0;
    .scope S_0x644ab268fbe0;
T_0 ;
    %wait E_0x644ab26576a0;
    %load/vec4 v0x644ab2656490_0;
    %load/vec4 v0x644ab26a2b00_0;
    %xor;
    %store/vec4 v0x644ab26a2c90_0, 0, 1;
    %load/vec4 v0x644ab2656490_0;
    %inv;
    %load/vec4 v0x644ab26a2b00_0;
    %and;
    %store/vec4 v0x644ab26a2bc0_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x644ab268fa50;
T_1 ;
    %vpi_call 2 6 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call 2 7 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x644ab268fa50 {0 0 0};
    %vpi_call 2 8 "$monitor", "Time = %0t A = %b B=%b Sum = %b Carry = %b", $time, v0x644ab26a2e00_0, v0x644ab26a2ec0_0, v0x644ab26a3090_0, v0x644ab26a2f90_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644ab26a2e00_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644ab26a2ec0_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644ab26a2e00_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644ab26a2ec0_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644ab26a2e00_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x644ab26a2ec0_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644ab26a2e00_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x644ab26a2ec0_0, 0, 1;
    %delay 5, 0;
    %vpi_call 2 13 "$finish" {0 0 0};
    %end;
    .thread T_1;
