#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5c506a240000 .scope module, "full_adder_tb" "full_adder_tb" 2 1;
 .timescale 0 0;
v0x5c506a2548c0_0 .var "a", 0 0;
v0x5c506a254980_0 .var "b", 0 0;
v0x5c506a254a20_0 .var "cin", 0 0;
v0x5c506a254af0_0 .net "cout", 0 0, v0x5c506a254650_0;  1 drivers
v0x5c506a254bc0_0 .net "s", 0 0, v0x5c506a254710_0;  1 drivers
S_0x5c506a240190 .scope module, "uut" "full_adder" 2 4, 3 1 0, S_0x5c506a240000;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /INPUT 1 "cin";
    .port_info 3 /OUTPUT 1 "s";
    .port_info 4 /OUTPUT 1 "cout";
v0x5c506a240390_0 .net "a", 0 0, v0x5c506a2548c0_0;  1 drivers
v0x5c506a2544f0_0 .net "b", 0 0, v0x5c506a254980_0;  1 drivers
v0x5c506a2545b0_0 .net "cin", 0 0, v0x5c506a254a20_0;  1 drivers
v0x5c506a254650_0 .var "cout", 0 0;
v0x5c506a254710_0 .var "s", 0 0;
E_0x5c506a206b60 .event anyedge, v0x5c506a240390_0, v0x5c506a2544f0_0, v0x5c506a2545b0_0;
    .scope S_0x5c506a240190;
T_0 ;
    %wait E_0x5c506a206b60;
    %load/vec4 v0x5c506a240390_0;
    %load/vec4 v0x5c506a2544f0_0;
    %xor;
    %load/vec4 v0x5c506a2545b0_0;
    %xor;
    %store/vec4 v0x5c506a254710_0, 0, 1;
    %load/vec4 v0x5c506a240390_0;
    %load/vec4 v0x5c506a2544f0_0;
    %and;
    %load/vec4 v0x5c506a2545b0_0;
    %load/vec4 v0x5c506a240390_0;
    %load/vec4 v0x5c506a2544f0_0;
    %xor;
    %and;
    %or;
    %store/vec4 v0x5c506a254650_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x5c506a240000;
T_1 ;
    %vpi_call 2 6 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5c506a240000 {0 0 0};
    %vpi_call 2 7 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call 2 8 "$monitor", "Time = %0t A = %b B = %b C = %b S = %b cout = %b", $time, v0x5c506a2548c0_0, v0x5c506a254980_0, v0x5c506a254a20_0, v0x5c506a254bc0_0, v0x5c506a254af0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a2548c0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a254980_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a254a20_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a2548c0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a254980_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a254a20_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a2548c0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c506a254980_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a254a20_0, 0, 1;
    %delay 5, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a2548c0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a254980_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c506a254a20_0, 0, 1;
    %delay 5, 0;
    %vpi_call 2 13 "$finish" {0 0 0};
    %end;
    .thread T_1;
